TAPO_HOST=192.168.1.107
TAPO_USERNAME=your-tplink-email@example.com
TAPO_PASSWORD=your-tplink-password
TAPO_TIMEOUT=5
TAPO_CONNECTION=direct

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_TITLE=CAMPER VAN
DASHBOARD_TAPO_CONTROL_ID=p280_charge

DASHBOARD_FRESH_PERCENT=78
DASHBOARD_FRESH_LITRES=78
DASHBOARD_FRESH_CAPACITY_L=100
DASHBOARD_GREY_PERCENT=45
DASHBOARD_GREY_LITRES=45
DASHBOARD_GREY_CAPACITY_L=100

# Fresh and grey tank levels are read from the ADS1115 on the Raspberry Pi.
DASHBOARD_TANK_SOURCE=ads1115
DASHBOARD_TANK_ADC_ADDRESS=0x48
DASHBOARD_TANK_ADC_GAIN=1
DASHBOARD_TANK_SUPPLY_V=3.3
DASHBOARD_TANK_FIXED_OHMS=470
DASHBOARD_TANK_DIVIDER=sender_to_ground
DASHBOARD_FRESH_ADC_CHANNEL=0
DASHBOARD_FRESH_EMPTY_OHMS=0
DASHBOARD_FRESH_FULL_OHMS=190
DASHBOARD_GREY_ADC_CHANNEL=1
DASHBOARD_GREY_EMPTY_OHMS=0
DASHBOARD_GREY_FULL_OHMS=190

DASHBOARD_INSIDE_TEMP_C=20
DASHBOARD_OUTSIDE_TEMP_C=22
DASHBOARD_OUTSIDE_TEMP_SOURCE=static
DASHBOARD_BATTERY_PERCENT=85

# Temperature graph history. The dashboard samples the current inside/outside
# readings into this JSON file and uses it for the Day, Week, and Month graph.
DASHBOARD_TEMPERATURE_HISTORY_FILE=temperature_history.json
DASHBOARD_TEMPERATURE_SAMPLE_INTERVAL_S=300
DASHBOARD_TEMPERATURE_HISTORY_DAYS=180

# Use SwitchBot OpenAPI for the outdoor temperature instead of the static
# DASHBOARD_OUTSIDE_TEMP_C fallback. Requires the W3400010 Outdoor Meter to be
# in Bluetooth range of a SwitchBot Hub added to your SwitchBot account.
# Get the token and secret from SwitchBot app > Profile > Preferences > About,
# tap App Version 10 times, then Developer Options > Get Token.
# Set DASHBOARD_OUTSIDE_TEMP_SOURCE=switchbot for cloud API polling.
# Set DASHBOARD_OUTSIDE_TEMP_SOURCE=switchbot_ble for local Bluetooth polling.
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=
SWITCHBOT_DEVICE_ID=
SWITCHBOT_DEVICE_NAME=
SWITCHBOT_TIMEOUT=8
SWITCHBOT_BLE_ADDRESS=
SWITCHBOT_BLE_SCAN_SECONDS=10

# AFERIY P280 display. Use static until Bluetooth or BrightEMS MQTT is configured.
DASHBOARD_AFERIY_ENABLED=true
DASHBOARD_AFERIY_SOURCE=static
DASHBOARD_AFERIY_LABEL=AFERIY P280
DASHBOARD_AFERIY_MODEL=P280
DASHBOARD_AFERIY_CAPACITY_WH=2048
DASHBOARD_AFERIY_PERCENT=85
DASHBOARD_AFERIY_INPUT_W=0
DASHBOARD_AFERIY_OUTPUT_W=0
DASHBOARD_AFERIY_AC_OUTPUT_ON=false
DASHBOARD_AFERIY_DC_OUTPUT_ON=false
DASHBOARD_AFERIY_USB_OUTPUT_ON=false

# Set DASHBOARD_AFERIY_SOURCE=ble for direct local Bluetooth polling. If the
# address is blank, the dashboard scans for devices named POWER, FOSSIBOT,
# AFERIY, or SYDPOWER.
DASHBOARD_AFERIY_BLE_ADDRESS=
DASHBOARD_AFERIY_BLE_NAME_PREFIXES=POWER,FOSSIBOT,AFERIY,SYDPOWER
DASHBOARD_AFERIY_BLE_SCAN_SECONDS=10
DASHBOARD_AFERIY_BLE_POLL_SECONDS=5
DASHBOARD_AFERIY_BLE_TIMEOUT_S=20

# Set DASHBOARD_AFERIY_SOURCE=mqtt after enabling the local MQTT broker in
# the BrightEMS app and running a broker such as Mosquitto on the dashboard Pi.
DASHBOARD_AFERIY_MQTT_HOST=127.0.0.1
DASHBOARD_AFERIY_MQTT_PORT=1883
DASHBOARD_AFERIY_MQTT_USERNAME=
DASHBOARD_AFERIY_MQTT_PASSWORD=
DASHBOARD_AFERIY_MQTT_DEVICE_ID=
DASHBOARD_AFERIY_API_TOKEN=
DASHBOARD_AFERIY_TELEMETRY_TTL_S=90
